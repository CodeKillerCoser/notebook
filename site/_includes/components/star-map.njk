{# site/_includes/components/star-map.njk #}
{% if keywordCloud and keywordCloud.length %}
<section id="star-map" class="star-map-section" aria-label="文章关键词星图">
  <div class="corpus-map">
    <div class="corpus-map__rings" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <img
      class="corpus-map__planet"
      src="{{ '/assets/brand/low-entropy-planet.svg' | relativeUrl(page.url) }}"
      alt=""
      width="180"
      height="180"
      decoding="async"
    >
    <div class="corpus-map__words" role="list" aria-label="文章正文关键词分布">
      {% for item in keywordCloud %}
        <span
          class="corpus-keyword-anchor"
          role="listitem"
          data-orbit="{{ item.orbit }}"
          data-tier="{{ item.tier }}"
          data-rank="{{ item.rank }}"
          style="--importance: {{ item.importance }}; --distance: {{ item.distance }}%; --delay: {{ item.delay }}s;"
        >
          <a
            class="corpus-keyword"
            href="{{ item.url | relativeUrl(page.url) }}"
            data-related="{{ item.related | join(',') }}"
            aria-label="搜索包含“{{ item.text }}”的文章"
          >{{ item.text }}</a>
        </span>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
