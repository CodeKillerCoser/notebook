<!doctype html>
<html lang="zh-CN">
<head>
  {% if article %}
    {% set pageTitle = article.title ~ " | " ~ site.title %}
    {% set pageDescription = article.excerpt %}
  {% elif directory %}
    {% set pageTitle = directory.title ~ " | " ~ site.title %}
    {% set pageDescription = "当前目录：" ~ directory.path %}
  {% elif tagPage %}
    {% set pageTitle = "标签：" ~ tagPage.name ~ " | " ~ site.title %}
    {% set pageDescription = "标签文章：" ~ tagPage.name %}
  {% else %}
    {% set pageTitle = title or site.title %}
    {% set pageDescription = description or site.tagline or site.description %}
  {% endif %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="{{ '/feed.xml' | relativeUrl(page.url) }}">
  <link rel="stylesheet" href="{{ '/assets/site.css' | relativeUrl(page.url) }}">
  <link rel="stylesheet" href="{{ '/assets/tokens.css' | relativeUrl(page.url) }}">
  <link rel="stylesheet" href="{{ '/assets/star-map.css' | relativeUrl(page.url) }}">
  <link rel="stylesheet" href="{{ '/assets/theme-toggle.css' | relativeUrl(page.url) }}">
  <link rel="stylesheet" href="{{ '/assets/notebook-redesign-overrides.css' | relativeUrl(page.url) }}">
  {% block head %}{% endblock %}
</head>
{% set isHomePage = home or page.url == '/' or page.url == '/index.html' %}
<body class="{% if isHomePage %}page-home{% elif article %}page-article{% elif directory %}page-directory{% elif tagPage %}page-tag{% else %}page-plain{% endif %}">
  <div class="ambient-flow" aria-hidden="true"></div>
  <canvas class="ion-field" aria-hidden="true"></canvas>
  {% if article %}
    {% set heroTitle = article.title %}
    {% set heroEyebrow = article.eyebrow or article.category %}
    {% set heroSubtitle = article.excerpt %}
    {% set activeBreadcrumbs = article.breadcrumbs %}
    {% set heroChips = article.chips if article.chips.length else article.tags %}
    {% set tocItems = article.toc %}
  {% elif directory %}
    {% set heroTitle = directory.title %}
    {% set heroEyebrow = "Directory" %}
    {% set heroSubtitle = directory.description %}
    {% set activeBreadcrumbs = directory.breadcrumbs %}
    {% set heroChips = [] %}
    {% set tocItems = toc %}
  {% elif tagPage %}
    {% set heroTitle = "标签：" ~ tagPage.name %}
    {% set heroEyebrow = "Tag" %}
    {% set heroSubtitle = tagPage.articles.length ~ " 篇文章" %}
    {% set activeBreadcrumbs = tagPage.breadcrumbs %}
    {% set heroChips = [tagPage.name] %}
    {% set tocItems = toc %}
  {% else %}
    {% set heroTitle = site.title if isHomePage else title or site.title %}
    {% set heroEyebrow = site.eyebrow if isHomePage else eyebrow or site.eyebrow or site.title %}
    {% set heroSubtitle = site.tagline if isHomePage else description or site.tagline or site.description %}
    {% set activeBreadcrumbs = breadcrumbs %}
    {% set heroChips = chips or [] %}
    {% set tocItems = toc %}
  {% endif %}

  <header class="site-topbar">
    <a class="site-brand" href="{{ '/index.html' | relativeUrl(page.url) }}">
      <img class="site-brand-mark" src="{{ '/assets/brand/low-entropy-route-mark.svg' | relativeUrl(page.url) }}" alt="" width="30" height="30">
      <span class="site-brand-copy">
        <strong>{{ site.title }}</strong>
        <small>{{ site.englishName }}</small>
      </span>
    </a>
    <a class="site-mobile-search" href="{{ '/search.html' | relativeUrl(page.url) }}">搜索</a>
    <button class="site-menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu-panel">菜单</button>
    <div class="site-menu-panel" id="site-menu-panel">
      <nav class="site-nav site-primary-nav" aria-label="主要内容">
        <a class="{% if isHomePage %}is-active{% endif %}" {% if isHomePage %}aria-current="page"{% endif %} href="{{ '/index.html' | relativeUrl(page.url) }}">首页</a>
        <a class="{% if article or directory %}is-active{% endif %}" {% if article or directory %}aria-current="page"{% endif %} href="{{ '/index.html#recent' | relativeUrl(page.url) }}">笔记</a>
        <a class="{% if tagPage or page.url == '/tags/index.html' %}is-active{% endif %}" {% if tagPage or page.url == '/tags/index.html' %}aria-current="page"{% endif %} href="{{ '/tags/index.html' | relativeUrl(page.url) }}">标签</a>
        <a class="{% if about %}is-active{% endif %}" {% if about %}aria-current="page"{% endif %} href="{{ '/about.html' | relativeUrl(page.url) }}">关于</a>
      </nav>
      <nav class="site-nav site-tool-nav" aria-label="站点工具">
        <a class="site-search-link{% if page.url == '/search.html' %} is-active{% endif %}" {% if page.url == '/search.html' %}aria-current="page"{% endif %} href="{{ '/search.html' | relativeUrl(page.url) }}">搜索</a>
        <a href="{{ '/feed.xml' | relativeUrl(page.url) }}">RSS</a>
      </nav>
      {% include "components/theme-toggle.njk" %}
    </div>
  </header>

  <nav class="breadcrumb-bar" aria-label="博客路径">
    <a href="{{ '/index.html' | relativeUrl(page.url) }}">{{ site.title }}</a>
    {% if activeBreadcrumbs %}
      {% for crumb in activeBreadcrumbs %}
        {% if not (loop.first and crumb.url == '/index.html') %}
          <span aria-hidden="true">›</span>
          <a href="{{ crumb.url | relativeUrl(page.url) }}">{{ crumb.title }}</a>
        {% endif %}
      {% endfor %}
    {% endif %}
  </nav>

  <div class="page-shell">
    <header id="title-block-header" class="hero-grid">
      <div class="hero-spacer" aria-hidden="true"></div>
      <div class="hero-content{% if isHomePage %} home-hero{% endif %}">
        {% if isHomePage %}
          <div class="home-hero-lockup">
            <img class="home-hero-mark" src="{{ '/assets/brand/low-entropy-route-mark.svg' | relativeUrl(page.url) }}" alt="" width="148" height="148">
            <div class="home-hero-copy">
              <div class="eyebrow">{{ heroEyebrow }}</div>
              <h1>{{ heroTitle }}</h1>
            </div>
          </div>
        {% else %}
          <div class="eyebrow">{{ heroEyebrow }}</div>
          <h1>{{ heroTitle }}</h1>
        {% endif %}
        {% if heroSubtitle %}
          <p class="subtitle">{{ heroSubtitle }}</p>
        {% endif %}
        {% if isHomePage and site.description %}
          <p class="home-hero-note">{{ site.description }}</p>
        {% endif %}
        <div class="meta article-meta">
          {% if article and article.date %}
            <time class="chip meta-chip" datetime="{{ article.date | isoDate }}">{{ article.date | readableDate }}</time>
          {% endif %}
          {% for chip in heroChips %}
            <span class="chip tag-chip">{{ chip }}</span>
          {% endfor %}
        </div>
        <hr class="article-divider">
      </div>
    </header>
  </div>

  <input class="toc-state" type="checkbox" id="mobile-toc-state" aria-hidden="true">
  <label class="toc-backdrop" for="mobile-toc-state" aria-hidden="true"></label>
  <label class="mobile-toc-button" for="mobile-toc-state" aria-controls="page-toc">
    <span>目录</span>
  </label>

  <div class="content-grid">
    <nav id="page-toc" class="toc" aria-label="目录">
      <div class="toc-head">
        <div class="toc-title">目录</div>
        <label class="toc-close" for="mobile-toc-state" aria-label="关闭目录">×</label>
      </div>
      {% if tocItems and tocItems.length %}
        <ol>
          {% for item in tocItems %}
            <li><a href="#{{ item.id }}">{{ item.text }}</a></li>
          {% endfor %}
        </ol>
      {% elif directory %}
        <ol>
          <li><a href="#overview">主题概览</a></li>
          {% if directory.children.length %}
            <li><a href="#children">主题入口</a></li>
          {% endif %}
          {% if directory.articles.length %}
            <li><a href="#recommended">推荐阅读</a></li>
            <li><a href="#articles">全部文章</a></li>
          {% endif %}
        </ol>
      {% else %}
        <ol>
          {% for directory in notebook.topDirectories %}
            <li><a href="{{ directory.permalink | relativeUrl(page.url) }}">{{ directory.title }}</a></li>
          {% endfor %}
          <li><a href="{{ '/search.html' | relativeUrl(page.url) }}">搜索</a></li>
          <li><a href="{{ '/tags/index.html' | relativeUrl(page.url) }}">标签</a></li>
        </ol>
      {% endif %}
      <label class="toc-footer-close" for="mobile-toc-state">收起目录</label>
    </nav>

    <main class="article-content" data-pagefind-body>
      {{ content | safe }}
    </main>
  </div>
  <script>
    (() => {
      const topbar = document.querySelector(".site-topbar");
      const toggle = document.querySelector(".site-menu-toggle");
      const panel = document.getElementById("site-menu-panel");
      if (!topbar || !toggle || !panel) return;

      const setOpen = (open) => {
        panel.classList.toggle("is-open", open);
        toggle.setAttribute("aria-expanded", String(open));
      };

      toggle.addEventListener("click", () => setOpen(!panel.classList.contains("is-open")));
      panel.addEventListener("click", (event) => {
        if (event.target.closest("a")) setOpen(false);
      });
      document.addEventListener("click", (event) => {
        if (!topbar.contains(event.target)) setOpen(false);
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpen(false);
      });
    })();

    (() => {
      const state = document.getElementById("mobile-toc-state");
      const toc = document.getElementById("page-toc");
      if (!state || !toc) return;
      toc.addEventListener("click", (event) => {
        if (event.target.closest("a")) state.checked = false;
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") state.checked = false;
      });

      const links = [...toc.querySelectorAll('a[href^="#"]')];
      const targets = links
        .map((link) => document.getElementById(decodeURIComponent(link.getAttribute("href").slice(1))))
        .filter(Boolean);
      if ("IntersectionObserver" in window && targets.length) {
        const activate = (id) => {
          links.forEach((link) => link.classList.toggle("is-active", link.getAttribute("href") === `#${id}`));
        };
        const observer = new IntersectionObserver((entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
          if (visible) activate(visible.target.id);
        }, { rootMargin: "-18% 0px -68% 0px", threshold: 0 });
        targets.forEach((target) => observer.observe(target));
      }
    })();

    (() => {
      const canvas = document.querySelector(".ion-field");
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      if (!canvas || reduceMotion.matches) return;

      const ctx = canvas.getContext("2d", { alpha: true });
      const palette = ["#2563eb", "#0f766e", "#c2410c", "#7e22ce", "#0369a1"];
      let width = 0;
      let height = 0;
      let dpr = 1;
      let particles = [];
      let raf = 0;

      const resize = () => {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const emit = (x, y, count = 14) => {
        const now = performance.now();
        for (let i = 0; i < count; i += 1) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1.2 + Math.random() * 2.8;
          particles.push({
            x,
            y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed - .35,
            life: 580 + Math.random() * 520,
            born: now,
            size: 1.4 + Math.random() * 2.8,
            color: palette[Math.floor(Math.random() * palette.length)]
          });
        }
        if (!raf) raf = requestAnimationFrame(tick);
      };

      const tick = (time) => {
        raf = 0;
        ctx.clearRect(0, 0, width, height);
        particles = particles.filter((p) => {
          const age = time - p.born;
          if (age > p.life) return false;
          const t = age / p.life;
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= .985;
          p.vy = p.vy * .985 + .018;
          const alpha = Math.sin((1 - t) * Math.PI) * .72;
          ctx.globalAlpha = alpha;
          ctx.fillStyle = p.color;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * (1 - t * .35), 0, Math.PI * 2);
          ctx.fill();
          return true;
        });
        ctx.globalAlpha = 1;
        if (particles.length) raf = requestAnimationFrame(tick);
      };

      resize();
      window.addEventListener("resize", resize, { passive: true });
      document.addEventListener("pointerdown", (event) => emit(event.clientX, event.clientY, 18), { passive: true });
      document.addEventListener("pointerover", (event) => {
        if (event.target.closest("a, button, label, input, summary, .directory-card, .chip")) {
          emit(event.clientX, event.clientY, 7);
        }
      }, { passive: true });
      document.addEventListener("focusin", (event) => {
        const box = event.target.getBoundingClientRect?.();
        if (box) emit(box.left + box.width / 2, box.top + box.height / 2, 10);
      });
    })();
  </script>
</body>
</html>
