{
  "name": "notebook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "eleventy --serve",
    "clean": "node scripts/clean-site.mjs",
    "build:site": "eleventy",
    "build:search": "pagefind --site _site --glob \"**/*.html\"",
    "build": "npm run clean && npm run build:site && npm run build:search",
    "migrate": "node scripts/migrate-to-11ty.mjs",
    "check:links": "node scripts/check-links.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "cheerio": "^1.0.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "pagefind": "^1.3.0"
  }
}
