{
  "name": "notebook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node tools/build-keywords.mjs && eleventy --serve",
    "clean": "node tools/clean-site.mjs",
    "build:keywords": "node tools/build-keywords.mjs",
    "build:site": "eleventy",
    "build:search": "pagefind --site _site --glob \"**/*.html\"",
    "build": "npm run clean && npm run build:keywords && npm run build:site && npm run build:search",
    "check:content": "node tools/check-content-integrity.mjs",
    "check:links": "node tools/check-links.mjs",
    "publish": "node tools/publish.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "cheerio": "^1.0.0",
    "gray-matter": "^4.0.3",
    "lxgw-wenkai-screen-webfont": "1.7.0",
    "markdown-it": "^14.1.0",
    "pagefind": "^1.3.0",
    "prismjs": "^1.30.0"
  }
}
