---
layout: layouts/base.njk
title: Notebook
permalink: /index.html
breadcrumbs:
  - title: Notebook
    url: /index.html
---
<section class="home">
  <h1>Notebook</h1>
  <p class="lead">个人技术笔记与工程实践记录。这里按主题维护学习材料、工程笔记和长期可复用的知识入口。</p>

  <form class="home-search" action="{{ '/search.html' | relativeUrl(page.url) }}">
    <input name="q" type="search" placeholder="搜索 Rust、Agent、Git 部署..." aria-label="搜索关键词">
    <button type="submit">搜索</button>
  </form>

  <h2>主题目录</h2>
  <div class="directory-grid">
    {% for directory in notebook.topDirectories %}
      <a class="directory-card" href="{{ directory.permalink | relativeUrl(page.url) }}">
        <strong>{{ directory.title }}</strong>
        <span>{{ directory.children.length }} 个子目录 · {{ directory.articles.length }} 篇直属文章</span>
      </a>
    {% endfor %}
  </div>

  <h2>最近更新</h2>
  <ol class="article-list">
    {% for article in notebook.articles | limit(12) %}
      <li>
        <a href="{{ article.url | relativeUrl(page.url) }}">{{ article.title }}</a>
        <span>{{ article.category }} · {{ article.date | readableDate }}</span>
      </li>
    {% endfor %}
  </ol>
</section>
